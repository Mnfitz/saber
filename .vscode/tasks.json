// Invoke me via Command Palette: Run Tasks

{
  "version": "2.0.0",
  "options": {
    // WARNING: Make sure that your ~/.bashrc doesn't manually set
    // a current working directory for you; eg. 'cd' command.
    // Otherwise, it will undo this "cwd" tuple and you
    // will get the error "make failed with code 2."
    "cwd": "${workspaceFolder}"
  },

  "tasks": [
    {
      "label": "generate",
      "type": "shell",
      "windows": {
        "command": "cmake",
        "args": [
          "--preset", "config-win-${input:configGeneratorWin}",
          "-A", "${input:buildPlatform}"
        ]
      },
      "osx": {
        "command": "cmake",
        "args": [
          "--preset", "config-${input:configGeneratorApple}-xcode"
        ]
      },
      "linux": {
        "command": "cmake",
        "args": [
          "--preset",
          "config-linux-make",
          "-A", "${input:buildPlatform}",
          "-DCMAKE_BUILD_TYPE=${input:buildConfig}"
        ]
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },

    {
      "label": "build",
      "type": "shell",
      "windows": {
        "command": "cmake",
        "args": [
          "--build",
          "--preset", "build-win-${input:configGeneratorWin}",
          "-A", "${input:buildPlatform}",
          "--config", "${input:buildConfig}"
        ]
      },
      "osx": {
        "command": "cmake",
        "args": [
          "--build",
          "--preset", "build-${input:configGeneratorApple}-xcode",
          "--config", "${input:buildConfig}"
        ]
      },
      "linux": {
        "command": "cmake",
        "args": [
          "--build",
          "--preset", "build-linux-make",
          "-A", "${input:buildPlatform}",
          "-DCMAKE_BUILD_TYPE$={input:buildConfig}"
        ]
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },

    {
      "label": "clean",
      "type": "shell",
      "windows": {
        "command": "cmake --build --preset build-win-${input:configGeneratorWin} --target clean"
      },
      "osx": {
        "command": "cmake --build --preset build-${input:configGeneratorApple}-xcode --target clean"
      },
      "linux": {
        "command": "cmake --build --preset build-linux-make --target clean"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    }
  ],

  "inputs": [
    {
      "id": "configGeneratorWin",
      "type": "pickString",
      "description": "Choose VS config generator [vs2022]",
      "options": [ "vs2022", "vs2026" ],
      "default": "vs2022"
    },

    {
      "id": "configGeneratorApple",
      "type": "pickString",
      "description": "Choose Xcode config generator [macos]",
      "options": [ "macos", "ios" ],
      "default": "macos"
    },

    {
      "id": "buildPlatform",
      "type": "pickString",
      "description": "Choose build platform [x64]",
      "options": [ "x64", "arm64" ],
      "default": "x64"
    },

    {
      "id": "buildConfig",
      "type": "pickString",
      "description": "Choose build configuration [Debug]",
      "options": [ "Debug", "Release", "RelWithDebInfo", "MinSizeRel" ],
      "default": "Debug"
    }
  ]
}

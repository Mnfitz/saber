{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },

  "configurePresets": [

    {
      "name": "config-default",
      "hidden": true,
      "description": "Default build setting for saber/win",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "SABER_BUILD_UNITTESTS": "ON",
        "SABER_BUILD_BENCHMARKS": "ON",
        "SABER_BUILD_DOCS": "OFF"
      }
    },

    {
      "name": "config-default-win",
      "hidden": true,
      "description": "Default build setting for saber/win",
      "inherits": "config-default",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },

    {
      "name": "config-win-vs2026",
      "displayName": "Configure Win VS2026",
      "generator": "Visual Studio 18 2026",
      "inherits": "config-default-win",
      "binaryDir": "${sourceDir}/build/win-vs2026",
      "toolset": {
        "value": "v145",
        "strategy": "external"
      }
    },

    {
      "name": "config-win-vs2022",
      "displayName": "Configure Win VS2022",
      "generator": "Visual Studio 17 2022",
      "inherits": "config-default-win",
      "binaryDir": "${sourceDir}/build/win-vs2022",
      "toolset": {
        "value": "v143",
        "strategy": "external"
      }
    },

    {
      "name": "config-win-vs2019",
      "displayName": "Configure Win VS2019",
      "generator": "Visual Studio 16 2019",
      "inherits": "config-default-win",
      "binaryDir": "${sourceDir}/build/win-vs2019",
      "toolset": {
        "value": "v142",
        "strategy": "external"
      }
    },

    {
      "name": "config-default-apple",
      "hidden": true,
      "description": "Default build setting for saber/apple",
      "inherits": "config-default",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      },
      "architecture": {
        "value": "arm64"
      }
    },

    {
      "name": "config-macos-xcode",
      "displayName": "Configure macOS Xcode",
      "generator": "Xcode",
      "inherits": "config-default-apple",
      "binaryDir": "${sourceDir}/build/macos-xcode",
      "cacheVariables": {
        "IOS": "OFF"
      }
    },

    {
      "name": "config-ios-xcode",
      "displayName": "Configure iOS Xcode",
      "generator": "Xcode",
      "inherits": "config-default-apple",
      "binaryDir": "${sourceDir}/build/ios-xcode",
      "cacheVariables": {
        "IOS": "ON"
      }
    },

    {
      "name": "config-default-linux",
      "hidden": true,
      "description": "Default build setting saber/Make",
      "generator": "Unix Makefiles",
      "inherits": "config-default",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      }
    },

    {
      "name": "config-linux-make",
      "displayName": "Configure Linux using Make",
      "binaryDir": "${sourceDir}/build/linux-make",
      "inherits": "config-default-linux"
    }
  ],

  "buildPresets": [
    {
      "name": "build-default-win",
      "hidden": true,
      "configurePreset": "config-default-win",
      "jobs": 0,
      "targets": [ "ALL_BUILD" ]
    },

    {
      "name": "build-win-vs2026",
      "configurePreset": "config-win-vs2026",
      "inherits": "build-default-win"
    },

    {
      "name": "build-win-vs2022",
      "configurePreset": "config-win-vs2022",
      "inherits": "build-default-win"
    },

    {
      "name": "build-win-vs2019",
      "configurePreset": "config-win-vs2019",
      "inherits": "build-default-win"
    },

    {
      "name": "build-default-apple",
      "hidden": true,
      "configurePreset": "config-default-apple",
      "jobs": 0,
      "targets": [ "ALL_BUILD" ]
    },

    {
      "name": "build-macos-xcode",
      "configurePreset": "config-macos-xcode",
      "inherits": "build-default-apple"
    },

    {
      "name": "build-ios-xcode",
      "configurePreset": "config-ios-xcode",
      "inherits": "build-default-apple"
    },

    {
      "name": "build-default-linux",
      "hidden": true,
      "configurePreset": "config-default-linux",
      "jobs": 0,
      "targets": [ "ALL_BUILD" ]
    },

    {
      "name": "build-linux-make",
      "configurePreset": "config-linux-make",
      "inherits": "build-default-linux"
    }
  ]
}
